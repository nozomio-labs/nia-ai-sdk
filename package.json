{
	"name": "@nozomioai/nia-ai-sdk",
	"version": "0.0.1",
	"license": "MIT",
	"packageManager": "bun@1.3.11",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"homepage": "https://github.com/nozomio-labs/nia-ai-sdk",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nozomio-labs/nia-ai-sdk.git"
	},
	"bugs": {
		"url": "https://github.com/nozomio-labs/nia-ai-sdk/issues"
	},
	"keywords": [
		"ai",
		"ai-sdk",
		"nozomioai",
		"nia",
		"adapter"
	],
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "bun test",
		"example:bun-server": "cd ./examples/bun-server && bun run dev",
		"example:bun-server:check": "cd ./examples/bun-server && bun run check:types",
		"check": "biome check .",
		"check:types": "tsc --noEmit",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "bun run build && changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@types/bun": "latest",
		"ai": "^6.0.145",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"ai": "^6.0.0",
		"zod": "^4.0.0"
	}
}
